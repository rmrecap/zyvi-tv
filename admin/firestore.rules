rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /app_settings/{document} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == 'rmrecap@gmail.com' || request.auth.token.firebase.sign_in_provider == 'google.com');
    }
    match /zyvi_config/{document} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == 'rmrecap@gmail.com' || request.auth.token.firebase.sign_in_provider == 'google.com');
    }
    match /zyvi_channels/{document} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == 'rmrecap@gmail.com' || request.auth.token.firebase.sign_in_provider == 'google.com');
    }
  }
}
